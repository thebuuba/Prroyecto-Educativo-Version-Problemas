PORT=4000

# Supabase PostgreSQL. Usa el Transaction Pooler o Session Pooler del proyecto.
# Desarrollo local con docker-compose.yml usa 5433 para no chocar con Postgres global.
DATABASE_URL=postgresql://aulabase:aulabase_dev@localhost:5433/aulabase
DATABASE_SSL=false

# En produccion debe incluir el origen real del frontend.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Supabase Auth. Esta clave es publicable; nunca uses service_role aqui.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu_clave_publica

# Genera un secreto largo y unico para produccion.
JWT_SECRET=change-me-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=aulabase_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
