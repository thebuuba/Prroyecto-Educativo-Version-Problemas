# Frontend publico. No pongas aqui service_role ni claves secretas.
# Desarrollo local:
VITE_API_URL=http://127.0.0.1:4000

# Produccion: usa la URL publica del backend SQL, por ejemplo:
# VITE_API_URL=https://aulabase-sql-api.onrender.com

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_tu_clave_publica

# IMPORTANTE para Vercel:
# En el dashboard de Vercel > Project Settings > Environment Variables, agrega:
#   VITE_API_URL     → https://aulabase-sql-api.onrender.com
#   VITE_SUPABASE_URL → https://zxuscgenmwseruvcaafm.supabase.co
#   VITE_SUPABASE_ANON_KEY → sb_publishable_...
# Sin estas vars, la app usara el fallback hardcodeado en index.html.
