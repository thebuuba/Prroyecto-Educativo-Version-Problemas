{
  "name": "edugest-main",
  "version": "1.0.0",
  "description": "EduGest Modernized with Vite and ES Modules",
  "type": "module",
  "scripts": {
    "dev": "NODE_DISABLE_COMPILE_CACHE=1 vite",
    "assemble": "./scripts/assemble-all.sh",
    "build": "NODE_DISABLE_COMPILE_CACHE=1 vite build",
    "preview": "NODE_DISABLE_COMPILE_CACHE=1 vite preview",
    "check": "npm run build && npm run imports:check && npm --prefix apps/api run check",
    "imports:check": "node scripts/check-imports.mjs",
    "backend:check": "npm --prefix apps/api run check",
    "backend:smoke": "cd apps/api && npm run smoke",
    "prepare:dist": "npm run assemble && npm run build"
  },
  "devDependencies": {
    "vite": "^6.4.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1"
  }
}
