# Frontend publico. No pongas aqui service_role ni claves secretas.
VITE_API_URL=http://127.0.0.1:4000
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_tu_clave_publica

# Backend Express. Puede vivir en apps/api/.env o heredarse del entorno.
PORT=4000
DATABASE_URL=postgresql://aulabase:aulabase_dev@localhost:5433/aulabase
DATABASE_SSL=false
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu_clave_publica
JWT_SECRET=change-me-with-a-long-random-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=aulabase_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
